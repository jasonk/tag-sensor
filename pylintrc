[MAIN]
ignore=
  tests,
  _version.py
ignore-paths = [ '.*/_.*.py$' ]

[BASIC]
class-const-naming-style=any
good-names=
  i,
  j,
  k,
  ev,
  ex,
  Run,
  _

[EXCEPTIONS]
overgeneral-exceptions=builtins.BaseException,builtins.Exception


[FORMAT]
expected-line-ending-format=LF
max-line-length=80
single-line-class-stmt=yes
single-line-if-stmt=yes

[MESSAGES CONTROL]
disable=
  fixme,
  cyclic-import,
  suppressed-message,
  locally-disabled,
  multiple-statements,
  wrong-import-order,
  wrong-import-position,
  too-many-arguments,
  too-many-positional-arguments,
  arguments-renamed,
  too-few-public-methods,
  too-many-public-methods,
  too-many-instance-attributes,
  too-many-ancestors,
  too-many-locals,
  duplicate-code,
  empty-docstring,
  missing-class-docstring,
  missing-function-docstring,
  missing-module-docstring,
  # missing-docstring,
  # invalid-name,
  # protected-access,

[REPORTS]
score=no

[TYPECHECK]
ignored-classes=
    _CountingAttr,
    SQLObject,
    optparse.Values,
    argparse.Namespace,
    thread._local,
    _thread._local,
generated-members=
  argparse.Namespace,
  cv2
contextmanager-decorators=contextlib.contextmanager
