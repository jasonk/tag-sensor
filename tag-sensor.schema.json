          "title": "Square Size",
          "type": "number"
        },
        "marker_size": {
          "default": 25.0,
          "description": "Size of the markers in the calibration grid.",
          "title": "Marker Size",
          "type": "number"
        },
        "samples": {
          "default": 20,
          "description": "Number of samples to take for calibration.",
          "title": "Samples",
          "type": "integer"
        },
        "delay": {
          "default": 3,
          "description": "Delay between samples for calibration.",
          "title": "Delay",
          "type": "number"
        },
        "attempts": {
          "default": 20,
          "description": "Maximum number of attempts to capture a frame for calibration.",
          "title": "Attempts",
          "type": "number"
        },
        "markers": {
          "default": 25,
          "description": "Minimum number of detected ids to consider a frame for calibration.",
          "title": "Markers",
          "type": "integer"
        },
        "family": {
          "default": "4X4",
          "enum": [
            "4X4",
            "5X5",
            "6X6",
            "7X7"
          ],
          "title": "Family",
          "type": "string"
        }
      },
      "title": "CalibrationConfig",
      "type": "object"
    },
